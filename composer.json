{
    "name": "percontmx/sportsvibe",
    "version": "1.0.0",
    "type": "project",
    "description": "Sports Vibe App",
    "autoload": {
        "psr-4": {
            "Percontmx\\SportsVibe\\Organizations\\": "modules/organizations/src",
            "Percontmx\\SportsVibe\\Competitions\\": "modules/competitions/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Percontmx\\SportsVibe\\Organizations\\Tests\\": "modules/organizations/tests",
            "Percontmx\\SportsVibe\\Organizations\\Tests\\Support\\": "modules/organizations/tests/_support",
            "Percontmx\\SportsVibe\\Competitions\\Tests\\": "modules/competitions/tests",
            "Percontmx\\SportsVibe\\Competitions\\Tests\\Support\\": "modules/competitions/tests/_support",
            "Tests\\": "tests",
            "Tests\\Support\\": "tests/_support"
        }
    },
    "require": {
        "php": ">=8.3",
        "codeigniter4/framework": "~4.5.0",
        "ext-intl": "*"
    },
    "require-dev": {
        "ext-sqlite3": "*",
        "phpunit/phpunit": "~10.5",
        "friendsofphp/php-cs-fixer": "^3.94",
        "codeigniter/coding-standard": "^1.9"
    },
     "scripts": {
        "format": "php-cs-fixer fix",
        "test": "phpunit"
    }
}
